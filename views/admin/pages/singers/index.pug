extends ../../layouts/default.pug

block main
  h1(class="mb-4") #{pageTitle}

  .card.mb-3
    .card-header Danh sách
    .card-body
      .row
        .col-8

        .col-4.text-right
          a(
            href=`/${prefixAdmin}/singers/create`
            class="btn btn-outline-success"
          ) + Thêm mới

      table(
        class="table table-hover table-sm"
      )
        thead
          tr
            th STT
            th Hình ảnh
            th Tên ca sĩ
            th Trạng thái
            th Hành động

        tbody
          each item, index in singers
            tr
              td #{index+1}
              td
                if item.avatar
                  img(
                    src=item.avatar
                    alt=item.fullName
                    width="100px"
                    height="auto"
                  )
                else
                  span -
              td #{item.fullName}
              td
                if (item.status === "active")
                  a(
                    href="javascript:;"
                    class="badge badge-success"
                  ) Hoạt động
                else
                  a(
                    href="javascript:;"
                    class="badge badge-danger"
                  ) Dừng hoạt động
              td
                a(
                  class="btn btn-warning btn-sm"
                  href=`/${prefixAdmin}/singers/edit/${item.id}`
                ) Sửa
                button(
                  class="btn btn-danger btn-sm ml-1"
                  button-delete
                  data-id=item.id
                  data-delete-url=`/${prefixAdmin}/singers/delete/${item.id}`
                ) Xóa
